<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.myhomelibcorp.ui.controller.BookEditController" prefWidth="500.0" prefHeight="550.0">
    <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>
    <Label text="Редагування книги" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <GridPane hgap="10.0" vgap="12.0" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="300.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="100.0" vgrow="ALWAYS" />
        </rowConstraints>
        <children>
            <Label text="Назва:"/><TextField fx:id="titleField" GridPane.columnIndex="1"/>
            <Label text="Серія:" GridPane.rowIndex="1"/><TextField fx:id="seriesField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label text="Номер у серії:" GridPane.rowIndex="2"/><TextField fx:id="sequenceNumberField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <Label text="Мова:" GridPane.rowIndex="3"/><ComboBox fx:id="languageBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            <Label text="Ключові слова:" GridPane.rowIndex="4"/><TextField fx:id="keywordsField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            <Label text="Анотація:" GridPane.rowIndex="5"/><TextArea fx:id="annotationArea" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" GridPane.rowSpan="3"/>
            <Label text="Оцінка:" GridPane.rowIndex="8"/><Spinner fx:id="rateSpinner" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
            <Label text="Прогрес:" GridPane.rowIndex="9"/><Slider fx:id="progressSlider" showTickLabels="true" showTickMarks="true" majorTickUnit="25.0" blockIncrement="5.0" GridPane.columnIndex="1" GridPane.rowIndex="9"/>
        </children>
    </GridPane>
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="btnSave" text="Зберегти" onAction="#handleSaveAction" prefWidth="100.0" style="-fx-font-weight: bold;"/>
        <Button fx:id="btnCancel" text="Скасувати" onAction="#handleCancelAction" prefWidth="100.0"/>
    </HBox>
</VBox>